rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: tasks
    // Document ID: taskId
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - createdAt: number (required)
    //   - uid: string (required)
    //   - fileCount: number (required)
    //   - results: list of objects (required)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }
    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "yaoxixi054@gmail.com" && request.auth.token.email_verified == true));
    }

    // Domain Validators
    function isValidTask(data) {
      return data.keys().hasAll(['id', 'name', 'createdAt', 'uid', 'fileCount', 'results']) &&
             data.id is string &&
             data.name is string && data.name.size() < 100 &&
             data.createdAt is number &&
             data.uid is string &&
             data.fileCount is number &&
             data.results is list && data.results.size() < 5000;
    }

    match /tasks/{taskId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidTask(request.resource.data) && request.resource.data.uid == request.auth.uid;
      allow update: if isDocOwner() && isValidTask(request.resource.data) && request.resource.data.uid == resource.data.uid;
      allow delete: if isDocOwner() || isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isOwner(userId) && (!('role' in request.resource.data) || request.resource.data.role == resource.data.role || isAdmin());
    }
  }
}
